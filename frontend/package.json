{
  "name": "noelcast",
  "displayName": "NoelCast",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "web": "expo start --web",
    "lint": "expo lint",
    "version:sync": "node scripts/sync-version.js",
    "android:bundle": "npm run version:sync && cd android && gradlew bundleRelease",
    "android:apk": "npm run version:sync && cd android && gradlew assembleRelease"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "expo": "~57.0.1",
    "expo-av": "^16.0.8",
    "expo-constants": "^57.0.2",
    "expo-font": "^57.0.0",
    "expo-image": "^57.0.0",
    "expo-linear-gradient": "^57.0.0",
    "expo-linking": "^57.0.1",
    "expo-router": "^57.0.2",
    "expo-splash-screen": "^57.0.1",
    "expo-status-bar": "~57.0.0",
    "expo-system-ui": "^57.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "^3.0.2",
    "react-native-reanimated": "^4.5.0",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.25.2",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.10.1"
  },
  "devDependencies": {
