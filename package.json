{
  "name": "noel-cast",
  "version": "1.0.0",
  "description": "🎄 NoelCast — A Christmas streaming radio app",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"API,EXPO\" --prefix-colors \"cyan,green\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "node scripts/start-backend.js",
    "dev:frontend": "cd frontend && npm run web",
    "install:frontend": "cd frontend && npm install",
    "setup": "node scripts/setup.js",
    "kill": "kill-port 8000 8081"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "kill-port": "^2.0.1"
  }
}
