# Allowed frontend origins (comma-separated)
# Add your deployed frontend URL here (e.g. https://your-app.netlify.app)
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,https://your-app.netlify.app

# Port (Render sets this automatically; set manually for local dev)
PORT=8000

# ── RAG Pipeline (AI Station Recommender) ─────────────────────────────────────

# Groq API Key (free tier — get yours at https://console.groq.com)
# Used for LLM generation (Llama 3.1 8B). No credit card required.
GROQ_API_KEY=your_groq_api_key_here

# AWS S3 (Free Tier — for storing the FAISS vector index)
# Create a free account at https://aws.amazon.com/free
# Then create an S3 bucket (e.g. noelcast-rag-index) and an IAM user with S3 access.
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=noelcast-rag-index
